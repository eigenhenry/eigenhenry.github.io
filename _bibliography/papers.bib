@article{brachoperez2026amplifying,
  abbr        = {JEE},
  bibtex_show = {true},
  title       = {Amplifying the Voices of Engineering Instructional Faculty: Examining the Factors Influencing Agency toward Impact at Hispanic-Serving Institutions},
