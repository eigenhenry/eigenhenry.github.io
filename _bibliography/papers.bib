@misc{cruz2025erroranalysis,
  abbr        = {HAL},
  bibtex_show = {true},
  title       = {Contribution to Error Analysis of Deep Neural Networks: Case of the Activation Functions},
  author      = {Cruz, M. L. R. and Ruiz-Rohena, K. and Guel, Y. I. and Salgado, Henry and Taldir, L. and Ramos, E. P. and Cervantes, N. and Rivero, T. and Ceberio, Martine and Lauter, C. and Volkova, A.},
  year        = {2025},
  month       = {November},
  html        = {https://inria.hal.science/hal-05367563/},
  abstract    = {Deep neural networks are widely used in high-stakes applications such as medical imaging and autonomous perception, where numerical reliability is as critical as predictive accuracy. While prior work has focused on gradient stability, the propagation of small floating-point errors through nonlinear network components remains underexplored. This paper provides a quantitative analysis of error amplification in common activation functions, including ReLU, sigmoid, tanh, and softmax.},
  selected    = {false},
  note        = {Preprint, Hal Open Science}
}

@inproceedings{salgado2026xai,
  abbr        = {xAI-26},
  bibtex_show = {true},
  title       = {A Causal Argumentation Method for Explainability of Machine Learning Models},
  author      = {Salgado, Henry and Kendall, Meagan R. and Ceberio, Martine},
  booktitle   = {4th World Conference on eXplainable Artificial Intelligence (xAI 2026)},
  year        = {2026},
  month       = {July},
  arxiv       ={https://arxiv.org/abs/2605.21758}, 
  abstract    = {Explainable AI (XAI) methods identify which features are relevant to a model's predictions but often fail to clarify why certain decisions are made. In this work, we present a novel method that integrates causality with argument-based reasoning to explain why models may be making predictions. Our approach first identifies causal relationships among variables using causal discovery methods and then translates these into a Bipolar Argumentation Framework (BAF) to represent supportive and opposing interactions among features. By using semi-stable semantics, we find extensions of features that explain why certain outcomes may have been chosen.},
  selected    = {true}
 
}

@misc{salgado2026calm,
  abbr        = {CALM-26},
  bibtex_show = {true},
  title       = {Causal Discovery for Explainable {AI}: {A} Dual-Encoding Approach},
  author      = {Salgado, Henry and Kendall, Meagan R. and Ceberio, Martine},
  year        = {2026},
  month       = {April},
  arxiv       = {2601.21221},
  doi         = {https://doi.org/10.1016/j.procs.2026.04.144},
  abstract    = {Understanding causal relationships among features is fundamental for explaining machine learning model decisions. However, traditional causal discovery methods face challenges with categorical variables due to numerical instability in conditional independence testing. We propose a dual-encoding causal discovery approach that addresses these limitations by running constraint-based algorithms with complementary encoding strategies and merging results through majority voting.},
  selected    = {true},

}
